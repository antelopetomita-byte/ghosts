rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function connExists(a, b) {
      return exists(/databases/$(database)/documents/connections/$(a + '__' + b))
          || exists(/databases/$(database)/documents/connections/$(b + '__' + a));
    }
    function isConnMember(conv) {
      return exists(/databases/$(database)/documents/connections/$(conv))
        && uid() in get(/databases/$(database)/documents/connections/$(conv)).data.members;
    }
    function isGroupMember(conv) {
      return exists(/databases/$(database)/documents/groups/$(conv))
        && uid() in get(/databases/$(database)/documents/groups/$(conv)).data.members;
    }

    match /users/{u} {
      allow read, write: if signedIn() && u == uid();
      match /contacts/{cid} {
        allow read:  if signedIn() && u == uid();
        allow write: if signedIn() && ( u == uid() || (cid == uid() && connExists(u, cid)) );
      }
    }

    match /invites/{token} {
      allow read:           if signedIn();
      allow create:         if signedIn() && request.resource.data.from == uid();
      allow update, delete: if signedIn() && resource.data.from == uid();
    }

    match /connections/{cid} {
      allow read, update, delete: if signedIn() && uid() in resource.data.members;
      allow create: if signedIn()
                    && uid() in request.resource.data.members
                    && request.resource.data.members.size() == 2;
    }

    match /groups/{gid} {
      allow read:   if signedIn() && uid() in resource.data.members;
      allow create: if signedIn() && uid() == request.resource.data.owner
                    && uid() in request.resource.data.members;
      allow update: if signedIn() && uid() in resource.data.members;
      allow delete: if signedIn() && uid() == resource.data.owner;
    }

    // --- push subscriptions: owner writes; connected peers can read (for sending notifications) ---
    match /pushSubs/{u} {
      allow write: if signedIn() && u == uid();
      allow read:  if signedIn() && ( u == uid() || connExists(u, uid()) );
    }

    match /chats/{conv}/messages/{mid} {
      allow read, create, update, delete: if signedIn()
        && ( isConnMember(conv) || isGroupMember(conv) );
    }
  }
}
